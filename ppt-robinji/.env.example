# ==========================================
# ppt-robinji AI Provider 配置
# ==========================================
# 默认 provider (deepseek / moonshot / qwen / zhipu / openrouter / groq / ollama / anthropic / openai)
PROVIDER=deepseek

# ==========================================
# OpenAI 兼容的第三方服务商
# ==========================================

# DeepSeek (https://platform.deepseek.com/api_keys) - 推荐，中文优秀
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Moonshot Kimi (https://platform.moonshot.cn/console/api-keys) - 长上下文
MOONSHOT_API_KEY=your_moonshot_api_key_here

# 通义千问 DashScope (https://dashscope.console.aliyun.com/apiKey) - 阿里云
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 智谱 GLM (https://bigmodel.cn/usercenter/apikeys) - 清华系
ZHIPU_API_KEY=your_zhipu_api_key_here

# OpenRouter (https://openrouter.ai/keys) - 聚合多模型
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Groq (https://console.groq.com/keys) - 超快推理
GROQ_API_KEY=your_groq_api_key_here

# Ollama (本地服务，无需 key) - 需先运行 `ollama serve`
# OLLAMA_API_KEY=not_required

# MiniMax (https://platform.MiniMax.cn/user-center/basic-information/interface-key) - 国产大模型
# baseURL: https://api.MiniMax.chat/v1
MINIMAX_API_KEY=your_MiniMax_api_key_here

# ==========================================
# 官方 API
# ==========================================

# Anthropic Claude (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# ==========================================
# 输出配置
# ==========================================
OUTPUT_DIR=./output
