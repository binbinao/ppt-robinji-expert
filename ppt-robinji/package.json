{
  "name": "ppt-robinji",
  "version": "2.6.0",
  "description": "Full-stack PPT skill - AI content generation, 14 slide types, 16 templates, 6 image sources, content-aware density, brand customization, multi-source input, animations, native shapes, TTS audio, A11y, and bilingual support. Powered by Node.js + pptxgenjs.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./ai": {
      "types": "./dist/ai/index.d.ts",
      "import": "./dist/ai/index.js",
      "require": "./dist/ai/index.cjs"
    },
    "./ai/generator": {
      "types": "./dist/ai/generator.d.ts",
      "import": "./dist/ai/generator.js",
      "require": "./dist/ai/generator.cjs"
    },
    "./ai/providers": {
      "types": "./dist/ai/providers.d.ts",
      "import": "./dist/ai/providers.js",
      "require": "./dist/ai/providers.cjs"
    },
    "./pptx": {
      "types": "./dist/pptx/index.d.ts",
      "import": "./dist/pptx/index.js",
      "require": "./dist/pptx/index.cjs"
    },
    "./pptx/creator": {
      "types": "./dist/pptx/creator.d.ts",
      "import": "./dist/pptx/creator.js",
      "require": "./dist/pptx/creator.cjs"
    },
    "./image": {
      "types": "./dist/image/index.d.ts",
      "import": "./dist/image/index.js",
      "require": "./dist/image/index.cjs"
    },
    "./image/image-service": {
      "types": "./dist/image/image-service.d.ts",
      "import": "./dist/image/image-service.js",
      "require": "./dist/image/image-service.cjs"
    },
    "./source": {
      "types": "./dist/source/index.d.ts",
      "import": "./dist/source/index.js",
      "require": "./dist/source/index.cjs"
    },
    "./pptx/animation": {
      "types": "./dist/pptx/animation/index.d.ts",
      "import": "./dist/pptx/animation/index.js",
      "require": "./dist/pptx/animation/index.cjs"
    },
    "./pptx/native": {
      "types": "./dist/pptx/native/index.d.ts",
      "import": "./dist/pptx/native/index.js",
      "require": "./dist/pptx/native/index.cjs"
    },
    "./audio": {
      "types": "./dist/audio/index.d.ts",
      "import": "./dist/audio/index.js",
      "require": "./dist/audio/index.cjs"
    },
    "./i18n": {
      "types": "./dist/i18n/index.d.ts",
      "import": "./dist/i18n/index.js",
      "require": "./dist/i18n/index.cjs"
    },
    "./converter": {
      "types": "./dist/converter/index.d.ts",
      "import": "./dist/converter/index.js",
      "require": "./dist/converter/index.cjs"
    },
    "./config/providers.json": "./config/providers.json"
  },
  "bin": {
    "ppt-robinji": "./dist/cli.js"
  },
  "files": [
    "dist",
    "config",
    "README.md",
    "SKILL.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "cli": "tsx src/cli.ts",
    "generate": "tsx scripts/generate-ppt.ts",
    "convert": "tsx scripts/convert.ts",
    "providers": "tsx scripts/list-providers.ts",
    "templates": "tsx scripts/list-templates.ts",
    "test": "tsx scripts/test.ts",
    "test:ai": "tsx scripts/test-ai.ts",
    "test:mock": "tsx scripts/test-mock-ai.ts",
    "test:templates": "tsx scripts/test-templates.ts",
    "test:density": "tsx scripts/test-density.ts",
    "test:images": "tsx scripts/test-images.ts",
    "test:v2": "tsx scripts/test-v2.ts",
    "test:p1": "tsx scripts/test-p1.ts",
    "test:e2e": "tsx scripts/test-e2e-v2.ts",
    "test:a11y": "tsx scripts/check-a11y.ts",
    "test:source": "tsx scripts/test-source.ts",
    "test:animation": "tsx scripts/test-animation.ts",
    "test:native": "tsx scripts/test-native.ts",
    "test:e2e-animation": "tsx scripts/test-e2e-animation.ts",
    "test:source-integration": "tsx scripts/test-source-integration.ts",
    "test:p0-integration": "tsx scripts/test-p0-integration.ts",
    "test:tts": "tsx scripts/test-tts.ts",
    "test:a11y-v2": "tsx scripts/test-a11y.ts",
    "test:bilingual": "tsx scripts/test-bilingual.ts",
    "demo": "tsx scripts/final-demo.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "pptx",
    "powerpoint",
    "ppt",
    "ai",
    "presentation",
    "slides",
    "slideshow",
    "ted",
    "pitch-deck",
    "speaker-notes",
    "codebuddy-skill"
  ],
  "author": "Robinji",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "mammoth": "^1.8.0",
    "openai": "^4.28.0",
    "pdf-parse": "^1.1.1",
    "pptxgenjs": "^3.12.0",
    "sharp": "^0.33.0",
    "zod": "^3.25.76"
  },
  "optionalDependencies": {
    "marked": "^12.0.0",
    "node-edge-tts": "^1.2.10"
  },
  "peerDependencies": {
    "tsx": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "tsx": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/sharp": "^0.31.1",
    "commander": "^12.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
