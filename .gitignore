# Dependencies
node_modules/
.pnp/
.pnp.js
.pnp.cjs

# Build outputs
ppt-robinji/dist/
ppt-robinji/.tsbuildinfo

# Local config and secrets
.env
.env.local
.env.*.local
!ppt-robinji/.env.example

# Output files (generated PPTs)
ppt-robinji/output/
*.pptx
!ppt-robinji/output/.gitkeep

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Cache
.cache/
.turbo/
.parcel-cache/
.next/
.nuxt/
.vite/

# Test coverage
coverage/
*.lcov
.nyc_output

# Misc
*.pid
*.seed
*.pid.lock

# CodeBuddy - keep skills/ tracked but exclude plans/cache
.codebuddy/plans/
.codebuddy/cache/
.codebuddy/logs/
.codebuddy/*.log
# Allow skills/ to be tracked
!.codebuddy/skills/

# ppt-robinji tutorial demos
docs/ppt-robinji-tutorial/demos/output/*
!docs/ppt-robinji-tutorial/demos/output/.gitkeep
